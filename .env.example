# Copy to .env and fill in values.

# Local development (no Atlas):
# MONGODB_URI=mongodb://127.0.0.1:27017/technews

# MongoDB Atlas — prefer "standard connection string" from Atlas Connect → Drivers.
# On Windows, mongodb+srv:// often fails with querySrv ECONNREFUSED in Node; use mongodb:// with:
#   tls=true, authSource=admin, replicaSet=... (from cluster TXT / connection modal), all shard hosts.
#
# Example shape (replace USER, PASS, hosts, replica set, DB name):
# MONGODB_URI=mongodb://USER:PASS@host0:27017,host1:27017,host2:27017/myapp?tls=true&authSource=admin&replicaSet=atlas-xxxxx-shard-0&retryWrites=true&w=majority
#
# SRV (works on some networks only):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/DATABASE_NAME?retryWrites=true&w=majority&appName=Cluster0

MONGODB_URI=
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
PORT=5000
CLIENT_URL=http://localhost:5173
NODE_ENV=development
